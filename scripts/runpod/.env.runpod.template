# ============================================================
# RunPod Configuration — copy to .env.runpod and fill in
# ============================================================
# cp scripts/runpod/.env.runpod.template scripts/runpod/.env.runpod
# Then edit .env.runpod with your values.
# ============================================================

# --- Required ---
# Your RunPod API key (from https://www.runpod.io/console/user/settings)
RUNPOD_API_KEY="your-api-key-here"

# --- Budget ---
# Maximum dollars to spend on this run. Pod auto-stops when limit is near.
# A100 SXM ~ $1.49/hr community cloud.
# Full pipeline takes ~9-14 hours = $13-21.
# Set higher than expected to avoid killing the sweep mid-run.
BUDGET_LIMIT_USD=40.00

# GPU hourly rate (check your RunPod dashboard for your actual rate)
# A100 SXM community = $1.49/hr as of May 2026
GPU_RATE_PER_HOUR=1.49

# --- Pod auto-stop behavior ---
# "stop"      = pause pod (preserves disk, stops billing GPU)
# "terminate" = destroy pod (loses everything — download results first!)
# Recommended: "stop" so you can inspect results before terminating.
ON_COMPLETE="stop"

# What to do on failure: "stop" or "continue_next"
# "stop"          = stop pod immediately on any script failure
# "continue_next" = skip failed step, try the next one, stop at end
ON_FAILURE="stop"

# --- Quick test mode ---
# Set to "true" to run a fast 15-minute test before the full pipeline.
# This trains just Switch on 10K examples to verify everything works.
# If the quick test passes, the full pipeline runs automatically.
QUICK_TEST_FIRST=true

# --- HuggingFace (optional) ---
# Read-only token for faster downloads and no rate-limiting.
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=""

# --- Notifications (optional) ---
# If set, a curl webhook fires on completion/failure.
# Works with Slack incoming webhooks, Discord, ntfy.sh, etc.
# Example (ntfy.sh, free, no signup):  https://ntfy.sh/your-secret-topic
# Example (Slack):  https://hooks.slack.com/services/T.../B.../xxx
NOTIFY_WEBHOOK_URL=""

# Notification message prefix (helps if you run multiple experiments)
NOTIFY_PREFIX="[energy-moe-m2]"
